# Dou Dizhu AI config for the simulator demo.
# Copy to `.uya_openai.env` or point `UYA_OPENAI_CONFIG_FILE` at your own file.
# `OPENAI_API_KEY` here is the client token for your Worker, not the upstream key.

UYA_DDZ_USE_OPENAI=1
OPENAI_API_KEY=ddz-client-token-here
OPENAI_MODEL=gpt-5.4-mini
OPENAI_BASE_URL=https://your-worker.workers.dev
OPENAI_API_PATH=/ddz/decision
